      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717",
      "950": "#0A0A0A"
    },
    "primary": {
      "50": "#F0FDF4",
      "100": "#DCFCE7",
      "200": "#BBF7D0",
      "300": "#86EFAC",
      "400": "#4ADE80",
      "500": "#22C55E",
      "600": "#16A34A",
      "700": "#15803D",
      "800": "#166534",
      "900": "#14532D",
      "950": "#052E16"
    },
    "semantic": {
      "success": {
        "light": "#DCFCE7",
        "DEFAULT": "#22C55E",
        "dark": "#15803D"
      },
      "warning": {
        "light": "#FEF3C7",
        "DEFAULT": "#F59E0B",
        "dark": "#B45309"
      },
      "error": {
        "light": "#FEE2E2",
        "DEFAULT": "#EF4444",
        "dark": "#B91C1C"
      },
      "info": {
        "light": "#DBEAFE",
        "DEFAULT": "#3B82F6",
        "dark": "#1D4ED8"
      }
    },
    "accent": {
      "purple": {
        "light": "#F3E8FF",
        "DEFAULT": "#A855F7",
