# Database
DATABASE_URL=postgresql+asyncpg://leed:leed_secret@localhost:5432/leed_platform
DATABASE_URL_SYNC=postgresql://leed:leed_secret@localhost:5432/leed_platform

# Restate
RESTATE_ADMIN_URL=http://localhost:9070
RESTATE_INGRESS_URL=http://localhost:8080

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_EVIDENCE=leed-evidence
S3_BUCKET_DOCUMENTS=leed-documents

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EXTRACTION_MODEL=gpt-4o

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Redis (optional cache)
REDIS_URL=redis://localhost:6379/0
