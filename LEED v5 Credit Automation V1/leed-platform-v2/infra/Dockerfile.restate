FROM python:3.12-slim AS base
WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir ".[dev]" 2>/dev/null || pip install --no-cache-dir .

COPY shared/ shared/
COPY agents/ agents/
COPY restate_services/ restate_services/
COPY skills/ skills/

EXPOSE 9080

RUN adduser --disabled-password --no-create-home appuser
USER appuser

CMD ["python", "-m", "hypercorn", "--bind", "0.0.0.0:9080", "restate_services.app:app"]
