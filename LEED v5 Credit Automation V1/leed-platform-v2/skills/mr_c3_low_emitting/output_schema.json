{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MRc3 Low-Emitting Materials — Output Schema",
  "type": "object",
  "required": ["extracted_products"],
  "properties": {
    "extracted_products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["product_name", "source_file", "confidence"],
        "properties": {
          "product_name": { "type": "string" },
          "manufacturer": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "adhesive_sealant",
              "paint_coating",
              "flooring",
              "composite_wood",
              "ceiling_wall",
              "insulation",
              "furniture"
            ]
          },
          "model_number": { "type": "string" },
          "voc_content": { "type": "string", "description": "VOC content with units, e.g. '35 g/L'" },
          "certification": { "type": "string", "description": "e.g. GREENGUARD Gold, FloorScore" },
          "certification_number": { "type": "string" },
          "certification_expiry": { "type": "string", "format": "date" },
          "source_file": { "type": "string" },
          "source_page": { "type": "integer", "minimum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "missing_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["missing_evidence"],
        "properties": {
          "product_name": { "type": "string" },
          "field_name": { "type": "string" },
          "missing_evidence": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
